# =============================================================================
# Twitch Emote Generator — 環境変数テンプレート
# =============================================================================
#
# このファイルは設定値の構造を示すサンプル。実値は `.env.local`（git 管理外）
# または Vercel 環境変数で管理する。
#
# 値の入手:
#   - PASSPHRASE: Aki が任意設定（PP 限定機能解除用）
#   - AUTH_*: Twitch Developer Console (https://dev.twitch.tv/console/apps)
#   - SUPABASE_*: Supabase ダッシュボード Settings → API
#   - ANTHROPIC_API_KEY: Anthropic Console (https://console.anthropic.com/)
#   - AUTH_TWITCH_BROADCASTER_ID: ADMIN_DELETION_SOP §3.2 の curl 手順で取得
# =============================================================================


# --- Authentication ---

# 既存のサブスク特典解除 PASSPHRASE（合言葉）。client/server で照合
PASSPHRASE=

# Auth.js (next-auth) のセッション暗号化キー。`openssl rand -base64 32` で生成
AUTH_SECRET=

# Twitch Developer Console で取得した OAuth アプリの Client ID / Secret
AUTH_TWITCH_ID=
AUTH_TWITCH_SECRET=

# fix7: フォロー判定対象のチャンネル user_id（Aki = datsusara_aki の数値ID）
# 取得手順: ADMIN_DELETION_SOP.md §3.2 の curl コマンド参照
# 設定が無い場合 isFollower=false 固定（safe fallback）
AUTH_TWITCH_BROADCASTER_ID=


# --- Database / External services ---

# Supabase プロジェクト URL（https://xxx.supabase.co 形式）
SUPABASE_URL=

# Supabase service_role key（RLS バイパス用、サーバーサイドのみ使用）
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key（AI アニメ生成）
ANTHROPIC_API_KEY=


# --- fix7: 緊急縮退 killswitch（FOLLOWER_AUTH_DESIGN.md §6） ---
#
# 各 killswitch は独立切替。値が "false" / "0" / "" のいずれかなら無効化、
# それ以外は有効（true）。デフォルト（変数自体が無い）も全て有効。
#
# 緊急時の段階的縮退（軽症 → 重症）:
#   1. DOWNLOAD_LOCK_ENABLED=false → DL は全員可、特典機能はロック維持
#   2. + PREMIUM_LOCK_ENABLED=false → 全機能解放、follower 判定は継続
#   3. + TRIAL_MODE_ENABLED=false → 完全に「フォロー認証を試みている形跡」を消す
#   4. FOLLOW_AUTH_ENABLED=false → /helix/channels/followed API 完全停止
#                                   （Twitch API 障害時の fallback）

# fix14: サイト全体ロック。true で未解放ユーザーに合言葉ゲート画面を表示
# （ツール本体は合言葉 or Twitch フォローで解放）。false でゲート撤去 →
# trial/premium の旧 2 階層挙動に戻る
SITE_LOCK_ENABLED=true

# trial 版制限の master killswitch。false で全ユーザー premium 扱い
TRIAL_MODE_ENABLED=true

# フォロー判定機能の master killswitch。fix14.1 で default false に反転
# （サイトロックの解放経路は合言葉のみ）。true を明示するとフォロー解放が復活
FOLLOW_AUTH_ENABLED=false

# 既存サブスク特典（限定アニメ・フレーム・カスタムフチ色等）のロック
PREMIUM_LOCK_ENABLED=true

# DL 制限（trial: 28px PNG のみ通過、56/112 と全 GIF を 403）
DOWNLOAD_LOCK_ENABLED=true
